{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    // Mirror cyberstrike's tsconfig settings — required because we import cyberstrike source directly
    "types": [],
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@/*": ["../cyberstrike/src/*"],
      "@tui/*": ["../cyberstrike/src/cli/cmd/tui/*"]
    }
  },
  "exclude": ["test-cases"]
}
